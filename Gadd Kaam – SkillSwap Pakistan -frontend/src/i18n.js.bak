  }
};

Object.entries(readableLanguageOverrides).forEach(([lng, bundle]) => {
  i18n.addResourceBundle(lng, 'translation', bundle, true, true);
});

const englishFallbackBundle = i18n.getResourceBundle('en', 'translation') || {};
['ur', 'sd'].forEach((lng) => {
  const bundle = i18n.getResourceBundle(lng, 'translation') || {};
  Object.entries(bundle).forEach(([key, value]) => {
    if (typeof value === 'string' && value.includes('???') && englishFallbackBundle[key]) {
      i18n.addResource(lng, 'translation', key, englishFallbackBundle[key]);
    }
  });
});

export default i18n;

